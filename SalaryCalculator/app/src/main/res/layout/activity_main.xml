<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <EditText
        android:id="@+id/etBasicPay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Basic Salary"
        android:inputType="numberDecimal"
        android:textSize="24sp"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnCalculate"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:text="Calculate Salary"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@+id/etBasicPay" />

    <TextView
        android:id="@+id/tvSalaryBreakdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Salary breakdown will appear here."
        android:textSize="20sp"
        android:lineSpacingExtra="8dp"
        app:layout_constraintTop_toBottomOf="@+id/btnCalculate" />

</androidx.constraintlayout.widget.ConstraintLayout>